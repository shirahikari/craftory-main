# ── Postgres ──────────────────────────────────────────────────
# Generate a strong random password: openssl rand -base64 32
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production

# ── Cookies ───────────────────────────────────────────────────
# Generate: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://craftory.io.vn

# ── AI Provider (at least one is required for chatbot) ─────────
AI_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_URL=http://ollama:11434
AI_MODEL=gpt-4.1-mini
AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# ── SePay Payments ────────────────────────────────────────────
# Webhook API Key from SePay dashboard → WebHooks → "API Key" auth method.
# This is the Apikey value SePay sends in the Authorization header.
SEPAY_API_KEY=
# Bank account that SePay watches (linked at Ngân hàng → Kết nối tài khoản).
# Bank short code (VCB, MB, TCB, ACB, BIDV, ...) — used by qr.sepay.vn.
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=
