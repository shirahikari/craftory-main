# ── Database ─────────────────────────────────────────────────
# Use a strong random password in production: openssl rand -base64 32
DATABASE_URL="postgresql://craftory:craftory_pass@postgres:5432/craftory?schema=public"

# ── Server ───────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Cookies & Session ─────────────────────────────────────────
# Use a long random string (32+ chars). Generate: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string-in-production

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for local dev
ALLOWED_ORIGIN=http://localhost,http://localhost:5500,http://127.0.0.1:5500

# ── AI Provider ─────────────────────────────────────────────
# Choose: openai | anthropic | ollama
AI_PROVIDER=openai

# OpenAI-compatible (default, works with ShopAIKey too)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini
AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Anthropic (if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Ollama (if AI_PROVIDER=ollama, free local LLM)
# OLLAMA_URL=http://ollama:11434
# AI_MODEL=llama3.2

# ── SePay Payments ────────────────────────────────────────────
# Webhook API Key (Apikey value in the Authorization header SePay sends us).
# Get it at my.sepay.vn → WebHooks → + Thêm webhooks → "API Key" auth method.
SEPAY_API_KEY=

# Bank account linked at my.sepay.vn → Ngân hàng → Kết nối tài khoản.
# Short bank code: VCB, MB, TCB, ACB, BIDV, etc. — used by qr.sepay.vn.
SEPAY_BANK_CODE=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_NAME=

# ── Demo user seeding (disabled by default) ──────────────────
# Set SEED_DEMO_USERS=true to seed admin/employee accounts (dev only).
# All four variables below are required when SEED_DEMO_USERS=true.
# SEED_DEMO_USERS=true
# ADMIN_EMAIL=admin@example.com
# ADMIN_INITIAL_PASSWORD=change-me-strong-password
# EMPLOYEE_EMAIL=employee@example.com
# EMPLOYEE_INITIAL_PASSWORD=change-me-strong-password
