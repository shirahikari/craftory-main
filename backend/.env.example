# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://craftory:craftory_pass@postgres:5432/craftory?schema=public"

# ── Server ───────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Cookies & Session ─────────────────────────────────────────
# Use a long random string (32+ chars). Generate: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-long-random-string-in-production

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins for local dev
ALLOWED_ORIGIN=http://localhost,http://localhost:5500,http://127.0.0.1:5500

# ── AI Provider ─────────────────────────────────────────────
# Choose: openai | anthropic | ollama
AI_PROVIDER=openai

# OpenAI-compatible (default, works with ShopAIKey too)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini
AI_ENDPOINT=https://api.openai.com/v1/chat/completions

# Anthropic (if AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Ollama (if AI_PROVIDER=ollama, free local LLM)
# OLLAMA_URL=http://ollama:11434
# AI_MODEL=llama3.2
